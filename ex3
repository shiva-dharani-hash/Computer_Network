def xor(a, b):
    ans = ""
    for i in range(1, len(b)):
        if a[i] == b[i]:
            ans += "0"
        else:
            ans += "1"
    return ans

def mod2div(data, key):
    n = len(key)
    temp = data[:n]

    while n < len(data):
        if temp[0] == '1':
            temp = xor(key, temp) + data[n]
        else:
            temp = xor("0" * len(key), temp) + data[n]
        n += 1

    if temp[0] == '1':
        temp = xor(key, temp)
    else:
        temp = xor("0" * len(key), temp)

    return temp


def sender(data, key):
    data = data + "0" * (len(key) - 1)
    crc = mod2div(data, key)
    codeword = data[:-(len(key) - 1)] + crc

    print("\nSender")
    print("CRC :", crc)
    print("Codeword :", codeword)

    return codeword

def receiver(codeword, key):
    rem = mod2div(codeword, key)

    print("\nReceiver")
    if rem == "0" * (len(key) - 1):
        print("No Error")
    else:
        print("Error Detected")

data = input("Enter Data: ")
